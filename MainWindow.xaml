<Window x:Class="WDOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows Deployment &amp; Optimization Suite (WDOS)" 
        Height="850" Width="1350"
        MinHeight="720" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeepBlue}"
        Foreground="{StaticResource TextPrimary}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header Row -->
            <RowDefinition Height="60" />
            <!-- Content Row (Sidebar + Main Panel) -->
            <RowDefinition Height="*" />
            <!-- Status Bar Row -->
            <RowDefinition Height="35" />
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Border Grid.Row="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSlate}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="WDOS" FontWeight="Bold" FontSize="22" Foreground="{StaticResource AccentBlue}" />
                    <TextBlock Text="|" Foreground="{StaticResource BorderSlate}" Margin="10,0,10,0" FontSize="18" VerticalAlignment="Center" />
                    <TextBlock Text="Windows Deployment &amp; Optimization Suite" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#293548" CornerRadius="10" Padding="10,4,10,4">
                        <TextBlock Text="v1.0.0-Stable" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="240" />
                <!-- Content Area -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation -->
            <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSlate}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,15,0,0">
                        <Button x:Name="BtnOffline" Content="⚡ Çevrimdışı Mod" Style="{StaticResource SidebarButtonStyle}" Tag="Active" Click="NavButton_Click" />
                        <Button x:Name="BtnOnline" Content="🌐 Çevrimiçi Mod" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" />
                        <Button x:Name="BtnRepair" Content="🔧 Sistem Onarım" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" />
                        <Button x:Name="BtnHardware" Content="🖥️ Donanım Tanılama" Style="{StaticResource SidebarButtonStyle}" Click="NavButton_Click" />
                    </StackPanel>

                    <!-- Sidebar Footer -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource BorderSlate}" BorderThickness="0,1,0,0" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Yönetici Yetkisi" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" Margin="0,0,0,5" />
                            <TextBlock Text="Teknisyen Konsolu" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Active Content View -->
            <ContentControl x:Name="ActiveModulePresenter" Grid.Column="1" Padding="25" />
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#0F172A" BorderBrush="{StaticResource BorderSlate}" BorderThickness="0,1,0,0">
            <Grid Margin="15,0,15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left-aligned Status message -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource AccentGreen}" Margin="0,0,8,0" />
                    <TextBlock x:Name="TxtStatus" Text="System Status: Ready" FontSize="12" Foreground="{StaticResource TextPrimary}" />
                </StackPanel>

                <!-- Right-aligned System Diagnostics (CPU/RAM/OS Info) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtStatusOs" Text="OS: win-x64" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,15,0" />
                    <TextBlock Text="|" Foreground="{StaticResource BorderSlate}" Margin="0,0,15,0" FontSize="11" />
                    <TextBlock x:Name="TxtStatusCpu" Text="CPU: 0%" FontSize="11" Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource Monospace}" Margin="0,0,15,0" />
                    <TextBlock Text="|" Foreground="{StaticResource BorderSlate}" Margin="0,0,15,0" FontSize="11" />
                    <TextBlock x:Name="TxtStatusRam" Text="RAM: 0.0 / 0.0 GB (0%)" FontSize="11" Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource Monospace}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
