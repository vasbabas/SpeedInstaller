<UserControl x:Class="WDOS.Modules.OnlineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <!-- Title Section -->
            <RowDefinition Height="Auto" />
            <!-- Pre-Check Status & Profiles -->
            <RowDefinition Height="Auto" />
            <!-- App Categories TabControl -->
            <RowDefinition Height="*" />
            <!-- Action Trigger -->
            <RowDefinition Height="Auto" />
            <!-- Logging Console -->
            <RowDefinition Height="130" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Çevrimiçi Dağıtım Seti (Online)" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" />
            <TextBlock Text="Seçilen uygulamaları 'winget' üzerinden sessiz parametrelerle indirir ve arka planda sırayla kurar." FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,0" />
        </StackPanel>

        <!-- Precheck & Profiles Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Profiles -->
            <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSlate}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Profil Seçimi:" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Button Content="Ev" Style="{StaticResource ModernButtonStyle}" Background="#334155" Margin="0,0,5,0" Padding="8,4,8,4" Click="Profile_Click" Tag="Home" />
                    <Button Content="Ofis" Style="{StaticResource ModernButtonStyle}" Background="#334155" Margin="0,0,5,0" Padding="8,4,8,4" Click="Profile_Click" Tag="Office" />
                    <Button Content="Geliştirici" Style="{StaticResource ModernButtonStyle}" Background="#334155" Margin="0,0,5,0" Padding="8,4,8,4" Click="Profile_Click" Tag="Dev" />
                    <Button Content="Oyuncu" Style="{StaticResource ModernButtonStyle}" Background="#334155" Margin="0,0,8,0" Padding="8,4,8,4" Click="Profile_Click" Tag="Gamer" />
                    <Button Content="Seçimi Kaldır" Style="{StaticResource ModernButtonStyle}" Background="#ef4444" Padding="8,4,8,4" Click="ClearSelection_Click" />
                </StackPanel>
            </Border>

            <!-- System Prechecks -->
            <Border Grid.Column="1" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSlate}" BorderThickness="1" CornerRadius="8" Padding="10" MinWidth="300">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse x:Name="DotNetStatus" Width="8" Height="8" Fill="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock x:Name="TxtNetStatus" Text="Ağ: Kontrol Ediliyor..." FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,15,0" />
                    
                    <Ellipse x:Name="DotWingetStatus" Width="8" Height="8" Fill="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock x:Name="TxtWingetStatus" Text="Winget: Kontrol Ediliyor..." FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Categories TabControl -->
        <TabControl Grid.Row="2" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderSlate}" BorderThickness="1" Margin="0,0,0,10">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <ContentPresenter Content="{TemplateBinding Content}" Margin="10,6,10,6" />
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: Tarayıcı & Bulut -->
            <TabItem Header="🌐 İnternet &amp; Bulut">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tarayıcılar" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10" />
                        <CheckBox x:Name="ChkChrome" Content="Google Chrome" Tag="Google.Chrome" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkFirefox" Content="Mozilla Firefox" Tag="Mozilla.Firefox" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkBrave" Content="Brave Browser" Tag="Brave.Brave" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkEdge" Content="Microsoft Edge" Tag="Microsoft.Edge" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkOpera" Content="Opera" Tag="Opera.Opera" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkVivaldi" Content="Vivaldi" Tag="Vivaldi.Vivaldi" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkWaterfox" Content="Waterfox" Tag="Waterfox.Waterfox" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkTor" Content="Tor Browser" Tag="TorProject.TorBrowser" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Bulut Veri depolama &amp; Torrent" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10" />
                        <CheckBox x:Name="ChkGDrive" Content="Google Drive" Tag="Google.Drive" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkOneDrive" Content="OneDrive" Tag="Microsoft.OneDrive" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkDropbox" Content="Dropbox" Tag="Dropbox.Dropbox" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkQbit" Content="qBittorrent (Açık Kaynak)" Tag="qBittorrent.qBittorrent" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkTransmission" Content="Transmission (Açık Kaynak)" Tag="Transmission.Transmission" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkFileZilla" Content="FileZilla (Açık Kaynak)" Tag="FileZilla.FileZilla" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 2: Sistem & Tanı -->
            <TabItem Header="🛠 Sistem &amp; Tanı">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Sıkıştırıcılar &amp; Disk Araçları" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10" />
                        <CheckBox x:Name="ChkWinRar" Content="WinRAR" Tag="RARLab.WinRAR" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="Chk7Zip" Content="7-Zip (Açık Kaynak)" Tag="7zip.7zip" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkWizTree" Content="WizTree Disk Analizci" Tag="OfficialWizTree.WizTree" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkTreeSize" Content="TreeSize Free" Tag="JAMSoftware.TreeSize.Free" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkCrystalDisk" Content="CrystalDiskInfo (Sağlık)" Tag="CrystalDewWorld.CrystalDiskInfo" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkCrystalMark" Content="CrystalDiskMark (Benchmark)" Tag="CrystalDewWorld.CrystalDiskMark" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkCpuZ" Content="CPU-Z" Tag="CPUID.CPU-Z" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkGpuZ" Content="GPU-Z" Tag="TechPowerUp.GPU-Z" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkHwMonitor" Content="HWMonitor" Tag="CPUID.HWMonitor" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkAida64" Content="AIDA64 Extreme" Tag="FinalWire.AIDA64Extreme" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Uzak Bağlantı &amp; Temizlik / Güvenlik" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10" />
                        <CheckBox x:Name="ChkAnyDesk" Content="AnyDesk" Tag="AnyDeskSoftwareGmbH.AnyDesk" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkTeamViewer" Content="TeamViewer" Tag="TeamViewer.TeamViewer" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkRufus" Content="Rufus (Açık Kaynak)" Tag="Akeo.Rufus" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkBleachBit" Content="BleachBit (Açık Kaynak)" Tag="BleachBit.BleachBit" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkMalwarebytes" Content="Malwarebytes" Tag="Malwarebytes.Malwarebytes" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkAdwCleaner" Content="AdwCleaner" Tag="Malwarebytes.AdwCleaner" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 3: Ofis & Medya -->
            <TabItem Header="✍ Ofis &amp; Medya">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Ofis &amp; PDF" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10" />
                        <CheckBox x:Name="ChkAdobe" Content="Adobe Acrobat Reader" Tag="Adobe.Acrobat.Reader.64-bit" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkSumatra" Content="SumatraPDF (Açık Kaynak)" Tag="SumatraPDF.SumatraPDF" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkPdf24" Content="PDF24 Creator" Tag="PDF24.PDF24Creator" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkLibreOffice" Content="LibreOffice (Açık Kaynak)" Tag="LibreOffice.LibreOffice" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkThunderbird" Content="Thunderbird (Açık Kaynak)" Tag="Mozilla.Thunderbird" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkWpsOffice" Content="WPS Office" Tag="Kingsoft.WPSOffice" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Medya, Tasarım &amp; Ekran" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10" />
                        <CheckBox x:Name="ChkVlc" Content="VLC Media Player (Açık Kaynak)" Tag="VideoLAN.VLC" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkPotPlayer" Content="PotPlayer" Tag="Kakao.PotPlayer" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkKLite" Content="K-Lite Codec Pack Mega" Tag="CodecGuide.K-LiteCodecPack.Mega" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkSpotify" Content="Spotify" Tag="Spotify.Spotify" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkAudacity" Content="Audacity (Açık Kaynak)" Tag="Audacity.Audacity" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkHandbrake" Content="HandBrake (Açık Kaynak)" Tag="HandBrake.HandBrake" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkShareX" Content="ShareX (Açık Kaynak)" Tag="ShareX.ShareX" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkObs" Content="OBS Studio (Açık Kaynak)" Tag="Obsproject.OBSStudio" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkGimp" Content="GIMP (Açık Kaynak)" Tag="Gnu.GIMP" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkInkscape" Content="Inkscape (Açık Kaynak)" Tag="Inkscape.Inkscape" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkBlender" Content="Blender (Açık Kaynak)" Tag="BlenderFoundation.Blender" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 4: Geliştirici -->
            <TabItem Header="💻 Geliştirici">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Editörler &amp; Temel Araçlar" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10" />
                        <CheckBox x:Name="ChkVsCode" Content="VS Code" Tag="Microsoft.VisualStudioCode" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkGit" Content="Git (Açık Kaynak)" Tag="Git.Git" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkNotepad" Content="Notepad++" Tag="Notepad++.Notepad++" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkSublime" Content="Sublime Text" Tag="SublimeHQ.SublimeText" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkPython" Content="Python 3" Tag="Python.Python.3.11" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkNode" Content="Node.js LTS" Tag="OpenJS.NodeJS.LTS" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkIntelliJ" Content="IntelliJ IDEA Community" Tag="JetBrains.IntelliJIDEA.Community" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkEclipse" Content="Eclipse IDE" Tag="EclipseFoundation.EclipseIDE.Java" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Veritabanı, Sunucu &amp; Sanallaştırma" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10" />
                        <CheckBox x:Name="ChkWinSCP" Content="WinSCP (Açık Kaynak)" Tag="WinSCP.WinSCP" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkPutty" Content="PuTTY (Açık Kaynak)" Tag="SimonTatham.PuTTY" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkDBeaver" Content="DBeaver CE (Açık Kaynak)" Tag="dbeaver.dbeaver" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkHeidi" Content="HeidiSQL (Açık Kaynak)" Tag="AnsgarBecker.HeidiSQL" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkPostman" Content="Postman" Tag="Postman.Postman" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkVirtualBox" Content="VirtualBox" Tag="Oracle.VirtualBox" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkDocker" Content="Docker Desktop" Tag="Docker.DockerDesktop" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 5: Sosyal & Oyun -->
            <TabItem Header="🎮 Sosyal &amp; Oyun">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Sosyal Medya &amp; İletişim" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10" />
                        <CheckBox x:Name="ChkDiscord" Content="Discord" Tag="Discord.Discord" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkTelegram" Content="Telegram Desktop (Açık Kaynak)" Tag="Telegram.TelegramDesktop" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkSlack" Content="Slack" Tag="SlackTechnologies.Slack" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkZoom" Content="Zoom" Tag="Zoom.Zoom" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkTeams" Content="Microsoft Teams" Tag="Microsoft.Teams" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkSkype" Content="Skype" Tag="Microsoft.Skype" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Oyun İstemcileri" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,10" />
                        <CheckBox x:Name="ChkSteam" Content="Steam" Tag="Valve.Steam" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkEpic" Content="Epic Games Launcher" Tag="EpicGames.EpicGamesLauncher" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkEA" Content="EA App" Tag="ElectronicArts.EADesktop" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkGog" Content="GOG Galaxy" Tag="GOG.Galaxy" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkUbisoft" Content="Ubisoft Connect" Tag="Ubisoft.Connect" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Start Deployment -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Button x:Name="BtnStartDeploy" Content="🚀 SEÇİLEN UYGULAMALARI WINGET İLE SESSIZ KUR" Height="42" Style="{StaticResource ModernButtonStyle}" Click="BtnStartDeploy_Click" />
        </Grid>

        <!-- Logger Console -->
        <Border Grid.Row="4" Background="#020617" BorderBrush="{StaticResource BorderSlate}" BorderThickness="1" CornerRadius="8" Padding="10">
            <ScrollViewer x:Name="ScrollerLogs" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="TxtLogs" 
                         Background="Transparent" 
                         Foreground="{StaticResource AccentGreen}" 
                         FontFamily="{StaticResource Monospace}" 
                         FontSize="12" 
                         BorderThickness="0" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         Text="[WDOS Online Modülu] Ön denetimler yapılıyor, lütfen bekleyin...&#x0a;" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
